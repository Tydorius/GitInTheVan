GITV_SECRET_KEY=change-me-in-production
GITV_DEBUG=false
GITV_LOG_LEVEL=INFO

# HTTP→HTTPS redirect (set to 80 to redirect http://host to https://host:8000)
# Port 80 requires admin/sudo. Set to 0 to disable. Only active when SSL is enabled.
GITV_HTTP_REDIRECT_PORT=80

# Database (SQLAlchemy URL format)
# SQLite (default — single instance only):
GITV_DATABASE_URL=sqlite+aiosqlite:///./data/gitinthevan.db
# PostgreSQL (requires: pip install -e ".[postgres]"):
# GITV_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/gitinthevan
# MariaDB / MySQL (requires: pip install -e ".[mysql]"):
# GITV_DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/gitinthevan

# Connection pool settings (PostgreSQL / MariaDB only; ignored by SQLite)
GITV_DB_POOL_SIZE=10
GITV_DB_MAX_OVERFLOW=20
GITV_DB_POOL_RECYCLE=3600

# Deno binary path (for script sandbox). Leave empty to auto-detect.
GITV_DENO_PATH=

# Security
# Comma-separated list of allowed CORS origins. Use * for any (less secure).
GITV_CORS_ORIGINS=*

# Rate limiting (requests per minute)
GITV_RATE_LIMIT_ENABLED=true
GITV_RATE_LIMIT_PROXY_PER_MIN=60
GITV_RATE_LIMIT_API_PER_MIN=120

# Maximum request body size in bytes (default 10MB)
GITV_MAX_REQUEST_BODY_SIZE=10485760

# JWT token expiration (hours)
GITV_JWT_EXPIRATION_HOURS=24

# Minimum password length
GITV_MIN_PASSWORD_LENGTH=8

# Logging (auto-creates data/logs/gitinthevan.log if GITV_LOG_FILE is empty)
GITV_LOG_FILE=
GITV_LOG_MAX_SIZE_MB=1
GITV_LOG_RETENTION_DAYS=30

# HTTPS / SSL (required for accessing from other devices when using HTTPS services like JanitorAI)
# Leave empty for HTTP (works on localhost only from HTTPS pages).
# Use the Admin panel to generate a self-signed certificate, or set paths manually:
# GITV_SSL_CERTFILE=data/ssl/cert.pem
# GITV_SSL_KEYFILE=data/ssl/key.pem

# Set to false to disable auto-generation of self-signed certificates.
# Use this when running behind a reverse proxy (nginx, Caddy, Pangolin, Cloudflare Tunnel)
# or when providing your own certificates (e.g. Let's Encrypt).
GITV_GENERATE_CERTS=true

# Set to true when running behind a reverse proxy that handles TLS termination.
# Enables X-Forwarded-For/X-Forwarded-Proto header processing in uvicorn.
GITV_BEHIND_PROXY=false
